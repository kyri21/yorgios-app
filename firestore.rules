rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helpers ────────────────────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }
    function role() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    // D1 — permissions configurables (settings/permissions, éditées via AdminPermissions).
    // FAIL-OPEN (décision Arthur 2026-06-12) : une permission n'est bloquante que si elle
    // est explicitement présente ET false. Doc absent / rôle absent / clé absente ⇒ autorisé.
    // patron/administrateur ne figurent pas dans le doc ⇒ toujours autorisés.
    function permAllows(key) {
      return !exists(/databases/$(database)/documents/settings/permissions)
          || !(role() in get(/databases/$(database)/documents/settings/permissions).data)
          || !(key in get(/databases/$(database)/documents/settings/permissions).data[role()])
          || get(/databases/$(database)/documents/settings/permissions).data[role()][key] == true;
    }
    function isPatronOrManager() {
      return isAuth() && role() in ['patron', 'administrateur', 'manager'];
    }
    function isCuisine() {
      return isAuth() && role() in ['patron', 'administrateur', 'manager', 'cuisine'];
    }
    function isCorner() {
      return isAuth() && role() in ['patron', 'administrateur', 'manager', 'corner'];
    }
    function isAnyRole() {
      return isAuth() && role() in ['patron', 'administrateur', 'manager', 'cuisine', 'corner'];
    }
    function isPatron() {
      return isAuth() && role() in ['patron', 'administrateur'];
    }

    // ─── Users ──────────────────────────────────────────────────
    // Chaque user lit/modifie son propre profil ; patron/manager voient tout
    match /users/{uid} {
      allow read:   if isAuth() && (request.auth.uid == uid || isPatronOrManager());
      allow write:  if isAuth() && (request.auth.uid == uid || isPatronOrManager());
    }

    // ─── Planning ────────────────────────────────────────────────
    match /employees/{doc} {
      allow read:  if isAnyRole();
      allow write: if isPatronOrManager();
    }
    // planningWeeks + toutes les sous-collections (days, events)
    match /planningWeeks/{path=**} {
      allow read:  if isAnyRole();
      allow write: if isPatronOrManager();
    }
    // No-shows détectés par detectNoShow — lecture + qualification patron/manager.
    // (création par la CF via admin SDK ; update = marquage "qualifié" côté client)
    match /pointages_noshow/{id} {
      allow read, write: if isPatronOrManager();
    }
    // Journal d'audit du planning — APPEND-ONLY (valeur probante en cas de litige).
    // Lecture + création réservées patron/admin/manager ; update/delete INTERDITS à tous,
    // y compris le patron → trace inviolable, impossible à effacer ou falsifier.
    match /planning_audit/{id} {
      allow read:   if isPatronOrManager();
      allow create: if isPatronOrManager();
      allow update, delete: if false;
    }

    // ─── Cuisine ────────────────────────────────────────────────
    match /receptions/{doc} {
      allow read, write: if isCuisine();
    }
    match /lots_cuisine/{doc} {
      allow read:   if isAnyRole();     // corner lit les lots pour la Vitrine
      allow create: if isCuisine();     // seule la cuisine crée des lots
      allow update: if isAnyRole();     // corner archive/renvoie ; cuisine marque sent
      // D1 : configurable via settings/permissions (fail-open)
      allow delete: if isAnyRole() && permAllows('action_delete_lot');
    }
    match /lot_counters/{doc} {
      allow read, write: if isCuisine();
    }
    match /archives/{doc} {
      allow read, write: if isCuisine();
    }
    match /hygiene_cuisine/{doc} {
      allow read, write: if isCuisine();
    }

    // ─── Produits (partagé cuisine + corner) ────────────────────
    match /produits/{doc} {
      allow read:  if isAnyRole();
      allow write: if isPatronOrManager();
    }

    // ─── Catalogue (remplace produits — lecture tous, écriture patron/admin/manager) ──
    match /catalogue/{doc} {
      allow read:  if isAnyRole();
      allow write: if isPatronOrManager();
    }

    // ─── Températures (partagé cuisine + corner) ────────────────
    // Les deux sites utilisent la même collection ; lecture par tous,
    // écriture autorisée pour les deux sites (cuisine ET corner ont leurs propres frigos)
    match /temperatures/{doc} {
      allow read:          if isAnyRole();
      allow create, update: if isAnyRole();
      allow delete:         if isPatronOrManager();
    }

    // ─── Livraisons (cuisine crée le départ, corner reçoit) ─────
    match /livraisons/{doc} {
      allow read:   if isAnyRole();
      // Cuisine crée la livraison (départ avec departTempC)
      allow create: if isCuisine();
      // Corner met à jour la réception (receptionTempC, result)
      // Patron/manager peuvent aussi modifier pour les corrections
      allow update: if isCorner();
      // D1 : configurable via settings/permissions (fail-open)
      allow delete: if isCuisine() && permAllows('action_delete_livraison');
    }

    // ─── Corner ─────────────────────────────────────────────────
    match /hygiene_corner/{doc} {
      allow read, write: if isCorner();
    }
    match /corner_stock/{doc} {
      allow read, write: if isCorner();
    }
    match /corner_commandes/{doc} {
      allow read, write: if isCorner();
    }
    // Non-conformités : créées par corner lors du refus d'une livraison
    match /non_conformites/{doc} {
      allow read:         if isAnyRole();
      allow create:       if isCorner();
      allow update:       if isCorner();
      // D1 : NC = registre qualité HACCP, gouverné par la même clé que les AC (fail-open)
      allow delete:       if isPatronOrManager() && permAllows('action_delete_ac');
    }
    // Stockage frigo corner : géré exclusivement par corner
    match /stockage_frigo/{doc} {
      allow read, write: if isCorner();
    }
    // Pertes corner : saisie corner uniquement
    match /pertes_corner/{doc} {
      allow read, write: if isCorner();
    }

    // ─── Ruptures actives (corner → cuisine dashboard) ───────────
    match /ruptures_actives/{id} {
      allow read: if isAuth();
      allow create: if isCorner();
      allow update: if isCuisine();
      allow delete: if false;
    }

    // ─── Demandes de congés ─────────────────────────────────────
    match /conges_demandes/{id} {
      allow create: if isAnyRole();
      allow read:   if isPatronOrManager() || (isAnyRole() && request.auth.uid == resource.data.uid);
      allow update: if isPatronOrManager();
    }

    // ─── Messagerie ─────────────────────────────────────────────
    match /messages/{doc} {
      allow read, write: if isAnyRole();
    }

    // ─── Commandes externes ──────────────────────────────────────
    // create : public (formulaire client sans auth)
    // read/update : corner + patron + manager
    match /commandes_externes/{doc} {
      // Téléphone non vide obligatoire (anti-spam : la CF onNewCommande déduplique
      // par téléphone ; un tél. vide contournait le contrôle).
      // Le personnel authentifié saisit pour le client ; le formulaire PUBLIC (non
      // authentifié) doit fournir consentRgpd == true (conformité RGPD — G1).
      allow create: if request.resource.data.telephone is string
                    && request.resource.data.telephone.size() > 0
                    && (isAnyRole() || request.resource.data.consentRgpd == true);
      allow read, update: if isCorner();
    }

    // ─── Objectifs CA ────────────────────────────────────────────
    match /objectifs_ca/{doc} {
      allow read:  if isAnyRole();
      allow write: if isPatronOrManager();
    }

    // ─── Pointages ───────────────────────────────────────────────
    // Validation GPS déléguée à la CF createPointage (admin SDK)
    // Aucun create direct depuis le client n'est autorisé
    match /pointages/{doc} {
      allow create: if false; // CF createPointage uniquement (admin SDK bypasse ces règles)
      allow read:   if isAuth() && (request.auth.uid == resource.data.userId || isPatronOrManager());
    }

    // ─── Notifications log ───────────────────────────────────────
    match /notifications_log/{userId}/{rest=**} {
      allow read, write: if isAuth() && request.auth.uid == userId;
    }

    // ─── Paramètres admin ────────────────────────────────────────
    // Lecture : tous les rôles (corner/cuisine lisent alertMinC, ruptures, etc.)
    // Écriture : patron/administrateur uniquement (sauf primes_ca accessible manager)
    match /settings/primes_ca {
      allow read:  if isAnyRole();
      allow write: if isPatronOrManager();
    }
    match /settings/{doc} {
      allow read:  if isAnyRole();
      // B4 : managers peuvent écrire les réglages (ils ont déjà accès à /admin/settings)
      allow write: if isPatronOrManager();
    }

    // ─── Annonces obligatoires ────────────────────────────────────
    // Lecture : tous les employés (pour afficher le popup)
    // Création/désactivation/suppression : patron/admin/manager
    // Mise à jour readBy : tout employé authentifié (pour marquer comme lu)
    match /annonces/{id} {
      allow read:   if isAnyRole();
      allow create, delete: if isPatronOrManager();
      allow update: if isPatronOrManager() || isAnyRole();
    }

    // ─── Primes planning ─────────────────────────────────────────
    match /primes_mois/{doc} {
      allow read, write: if isPatronOrManager();
    }
    match /primes_employe/{doc} {
      allow read, write: if isPatronOrManager();
    }

    // ─── CRM / Customers ─────────────────────────────────────────
    // Écrit par Cloud Functions (admin SDK, bypasse les règles)
    // Lecture : patron/manager pour le suivi CRM
    match /customers/{doc} {
      allow read:  if isPatronOrManager();
      allow write: if false; // Cloud Functions admin SDK uniquement
    }
    match /crm_sync_log/{doc} {
      allow read:  if isPatronOrManager();
      allow write: if false; // Cloud Functions admin SDK uniquement
    }

    // ─── Devices (enregistrement iPad / tokens FCM) ───────────────
    match /devices/{uid} {
      allow read: if isAnyRole();
      // Chaque appareil peut écrire son propre doc ; patron/admin peuvent écrire aussi
      allow write: if isAuth() && (
        request.auth.uid == uid || role() in ['patron', 'administrateur']
      );
    }

    // ─── Deliveries (suivi Twilio) ────────────────────────────────
    match /deliveries/{id} {
      allow read: if isAnyRole();
      allow write: if false;  // écriture uniquement via CF backend (Admin SDK)
    }

    // ─── Documents à signer ───────────────────────────────────────
    match /documents_a_signer/{id} {
      allow read: if isAnyRole();
      allow create, delete: if isPatron();
      allow update: if isPatron() || (isAnyRole() && request.auth.uid in resource.data.targetUids);
    }

    // ─── GMAO Demandes ────────────────────────────────────────────
    match /gmao_demandes/{id} {
      allow read: if isAnyRole();
      allow create, update: if isPatronOrManager();
      allow delete: if isPatron();
    }

    // ─── Créta Gel Docs ───────────────────────────────────────────
    match /creta_gel_docs/{id} {
      allow read: if isAnyRole();
      allow create, update, delete: if isPatronOrManager();
    }

    // ─── Actions correctives HACCP ────────────────────────────────
    match /actions_correctives/{id} {
      allow read: if isAnyRole();
      allow create: if isAnyRole();
      allow update: if isPatronOrManager();
      // D1 : configurable via settings/permissions (fail-open)
      allow delete: if isPatronOrManager() && permAllows('action_delete_ac');
    }
  }
}
